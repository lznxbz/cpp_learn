{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build and run active cpp file",
            "type": "shell",
            "command": "bash",
            "args": [
                "-c",
                "/usr/bin/g++ -std=c++17 -g \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\""
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
